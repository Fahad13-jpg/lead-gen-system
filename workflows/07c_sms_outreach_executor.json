      "id": "fcd635e9-207b-4010-b8c1-57e79cafde4b",
      "name": "Get SMS-Ready Leads1"
    },
    {
      "parameters": {
        "jsCode": "const lead = $input.item.json;\n\n// Personalize SMS message\nlet smsMessage = lead.sms_message || `Hi! Quick question about ${lead.company_name}. Interested in discussing?`;\n\n// Replace placeholders\nsmsMessage = smsMessage\n  .replace(/{{company_name}}/g, lead.company_name)\n  .replace(/{{first_name}}/g, extractFirstName(lead.company_name));\n\n// Ensure under 160 characters\nif (smsMessage.length > 160) {\n  smsMessage = smsMessage.substring(0, 157) + '...';\n}\n\n// Add opt-out (required by law)\nsmsMessage += '\\n\\nReply STOP to opt-out';\n\nfunction extractFirstName(companyName) {\n  // Try to get first word as first name\n  const words = companyName.split(' ');\n  return words[0] || 'there';\n}\n\nreturn {\n  lead_id: lead.lead_id,\n  company_name: lead.company_name,\n  to_phone: lead.phone,\n  sms_body: smsMessage,\n  from_phone: process.env.TWILIO_PHONE_NUMBER,\n  priority: lead.priority,\n  lead_score: lead.lead_score\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        624,
        -96
      ],
      "id": "74f34f62-6fa1-4061-af13-eea9a037911d",
      "name": "Prepare SMS Message"
    },
