    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO outreach_activities (\n  lead_id,\n  channel,\n  status,\n  external_id,\n  sms_sid,\n  sent_at\n) VALUES (\n  {{ $('Prepare SMS Message').item.json.lead_id }},\n  'sms',\n  'sent',\n  '{{ $json.sid }}',\n  '{{ $json.sid }}',\n  NOW()\n)",
        "options": {}
