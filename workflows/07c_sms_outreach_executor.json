    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  el.lead_id,\n  cl.company_name,\n  cl.phone,\n  el.sms_should_use,\n  el.sms_message,\n  el.sms_timing,\n  el.priority,\n  el.lead_score,\n  el.outreach_status,\n  el.sms_status,\n  el.last_sms_sent_at,\n  EXTRACT(DAY FROM NOW() - COALESCE(el.last_contacted_at, cl.created_at)) as days_since_last_contact\nFROM enriched_leads el\nJOIN cleaned_leads cl ON el.lead_id = cl.id\nWHERE el.enrichment_stage = 3\nAND el.sms_should_use = TRUE\nAND cl.phone IS NOT NULL\nAND el.sms_status IS NULL\nAND (\n  (el.outreach_status = 'email_sent'\n  AND EXTRACT(DAY FROM NOW() - el.last_contacted_at) >= 3)\n  OR\n  (el.outreach_status IS NULL)\n)\nORDER BY el.lead_score DESC\nLIMIT 10",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
