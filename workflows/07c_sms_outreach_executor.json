      "name": "Get SMS-Ready Leads1"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const lead = $input.item.json;\n\n// Trial account verified numbers only\n// Add your verified test numbers here\nconst VERIFIED_NUMBERS = [\n  '+923175153405', // add your verified number\n];\n\nconst IS_TRIAL = true; // set false when you upgrade Twilio\n\nfunction extractFirstName(name) {\n  return name.split(' ')[0] || 'there';\n}\n\n// Skip unverified numbers in trial mode\nif (IS_TRIAL && !VERIFIED_NUMBERS.includes(lead.to_phone)) {\n  return {\n    skip: true,\n    lead_id: lead.lead_id,\n    reason: `Trial account — ${lead.to_phone} not verified`,\n    company_name: lead.company_name,\n  };\n}\n\nlet smsMessage = lead.sms_message ||\n  `Hi! Quick question about ${lead.company_name}. Interested in discussing?`;\n\nsmsMessage = smsMessage\n  .replace(/{{company_name}}/g, lead.company_name)\n  .replace(/{{first_name}}/g, extractFirstName(lead.company_name));\n\nconst optOut = '\\n\\nReply STOP to opt-out';\nif (smsMessage.length > 160 - optOut.length) {\n  smsMessage = smsMessage.substring(0, 157 - optOut.length) + '...';\n}\nsmsMessage += optOut;\n\nreturn {\n  skip: false,\n  lead_id: lead.lead_id,\n  company_name: lead.company_name,\n  to_phone: lead.phone,\n  sms_body: smsMessage,\n  from_phone: $env.TWILIO_PHONE_NUMBER || '+17407385542',\n  priority: lead.priority,\n  lead_score: lead.lead_score,\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
