    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  el.lead_id,\n  cl.company_name,\n  cl.phone,\n  el.sms_should_use,\n  el.sms_message,\n  el.sms_timing,\n  el.priority,\n  el.lead_score,\n  el.outreach_status,\n  el.last_sms_sent_at,\n  EXTRACT(DAY FROM NOW() - COALESCE(el.last_contacted_at, el.created_at)) as days_since_last_contact\nFROM enriched_leads el\nJOIN cleaned_leads cl ON el.lead_id = cl.id\nWHERE el.enrichment_stage = 3\nAND el.sms_should_use = TRUE\nAND cl.phone IS NOT NULL\nAND el.sms_status IS NULL\nAND (\n  el.outreach_status = 'email_sent' \n  AND EXTRACT(DAY FROM NOW() - el.last_contacted_at) >= 3\n  OR el.outreach_status IS NULL\n)\nORDER BY el.lead_score DESC\nLIMIT 10",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        208,
        0
      ],
      "id": "82fe8adc-a12f-48b2-afb8-ed928a8c8777",
      "name": "Get SMS-Ready Leads",
      "credentials": {
        "postgres": {
          "id": "Scc3yxojKZkvXpOL",
          "name": "Lead Database"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 2
          },
          "conditions": [
            {
              "id": "bb6be24f-b852-454a-9866-e99e5b4c4c28",
