      "name": "Log WhatsApp Activity",
      "credentials": {
        "postgres": {
          "id": "Scc3yxojKZkvXpOL",
          "name": "Lead Database"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE enriched_leads\nSET \n  whatsapp_status = 'sent',\n  last_whatsapp_sent_at = NOW(),\n  last_contacted_at = NOW()\nWHERE lead_id = {{ $('Prepare WhatsApp Message').item.json.lead_id }}",
        "options": {}
