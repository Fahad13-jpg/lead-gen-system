    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst leadId = $('Get Pending Emails').item.json.id;\n\n// Handle API errors gracefully\nif (!response || response.error) {\n  return {\n    lead_id: leadId,\n    email_valid: false,\n    email_verification_status: 'validation_failed'\n  };\n}\n\n// AbstractAPI response structure\nconst isDeliverable = response.deliverability === 'DELIVERABLE';\nconst isValid = \n  response.is_valid_format?.value === true &&\n  response.is_mx_found?.value === true &&\n  response.is_disposable_email?.value === false &&\n  isDeliverable;\n\nconst status = isDeliverable ? 'valid' : \n               response.deliverability === 'UNDELIVERABLE' ? 'invalid' : \n               'unknown';\n\nreturn {\n  lead_id: leadId,\n  email_valid: isValid,\n  email_verification_status: status\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1216,
        -96
      ],
      "id": "53f8cbbd-5338-4818-bb55-e62642786e0b",
      "name": "Parse & Update"
