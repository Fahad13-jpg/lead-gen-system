      "id": "d0af9515-c703-4ad9-b84d-e7381e77f4f8",
      "name": "Any to Process?"
    },
    {
      "parameters": {
        "jsCode": "const leads = $input.all();\nconst cleaned = [];\n\nfor (const item of leads) {\n  const raw = item.json;\n  const rawData = raw.raw_data || {};\n  const additionalData = raw.additional_data || {};\n\n  const cleanEmail = (email) => {\n    if (!email) return null;\n    const clean = email.toLowerCase().trim();\n    return /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(clean) ? clean : null;\n  };\n\n  const cleanPhone = (phone) => {\n    if (!phone) return null;\n    const c = phone.replace(/[^0-9+]/g, '');\n    return c.length >= 7 ? c : null;\n  };\n\n  // Check email and phone from all possible sources\n  const cleanedEmail = cleanEmail(raw.email || rawData.email || additionalData.email);\n  const cleanedPhone = cleanPhone(raw.phone || rawData.phone || additionalData.phone);\n\n  if (!cleanedEmail && !cleanedPhone) {\n    console.log('Skipping: ' + (raw.company_name || 'Unknown'));\n    continue;\n  }\n\n  cleaned.push({\n    staging_id: raw.id,\n    job_id: raw.job_id,\n    user_id: raw.user_id,\n    company_name: (raw.company_name || 'Unknown').substring(0, 255),\n    email: cleanedEmail,\n    phone: cleanedPhone,\n    website: raw.website?.substring(0, 255) || null,\n    address: raw.address?.substring(0, 1000) || null,\n    city: raw.city?.substring(0, 100) || null,\n    state: raw.state?.substring(0, 100) || null,\n    zip_code: (raw.zip || raw.zip_code)?.substring(0, 20) || null,\n    country: (raw.country || 'Unknown').substring(0, 10),\n    category: raw.category?.substring(0, 100) || null,\n    rating: rawData.totalScore || additionalData.rating || null,\n    review_count: rawData.reviewsCount || additionalData.review_count || 0,\n    latitude: rawData.location?.lat || additionalData.latitude || null,\n    longitude: additionalData.longitude || rawData.location?.lng || null\n  });\n}\n\nconsole.log('Cleaned: ' + cleaned.length + '/' + leads.length);\n\nreturn cleaned.map(item => ({ json: item }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -4288,
        1296
      ],
      "id": "5a5d26b3-2845-4247-96d1-fedacb4d363e",
      "name": "Clean Data"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=WITH input_data AS (\n  SELECT \n    {{ $json.staging_id }} as staging_id,\n    {{ $json.user_id }} as user_id,\n    $1 as email,\n    $2 as phone\n)\nSELECT \n  i.staging_id,\n  CASE WHEN c.id IS NULL THEN 0 ELSE 1 END as duplicate_count\nFROM input_data i\nLEFT JOIN cleaned_leads c ON c.user_id = i.user_id \n  AND (c.email = i.email OR c.phone = i.phone)\nLIMIT 1",
        "options": {
          "queryReplacement": "={{ $json.email }},={{ $json.phone }}"
        }
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
