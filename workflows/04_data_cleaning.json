        "mode": "runOnceForEachItem",
        "jsCode": "const duplicateResult = $input.item.json;\nconst leadData = $('Clean Data').item.json;\n\nreturn { ...leadData, duplicate_count: parseInt(duplicateResult.duplicate_count) || 0 };"
      },
