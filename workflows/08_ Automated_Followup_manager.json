    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  el.lead_id,\n  cl.company_name,\n  cl.email,\n  cl.phone,\n  el.follow_up_count,\n  el.outreach_status,\n  el.sms_status,\n  el.whatsapp_status,\n  oa.opened_at,\n  oa.clicked_at,\n  EXTRACT(DAY FROM NOW() - oa.sent_at) as days_since_sent\nFROM enriched_leads el\nJOIN cleaned_leads cl ON el.lead_id = cl.id\nLEFT JOIN outreach_activities oa ON el.lead_id = oa.lead_id AND oa.channel = 'email'\nWHERE oa.replied_at IS NULL\nAND el.follow_up_count < 4\nORDER BY el.lead_score DESC\nLIMIT 20",
        "options": {}
      },
