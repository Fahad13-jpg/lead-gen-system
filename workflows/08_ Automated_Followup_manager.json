    {
      "parameters": {
        "jsCode": "const aiResponse = $input.first().json.output || {};\nconst lead = $('Test Data - Follow-Up Ready').item.json;\n// Get AI-generated content\nconst subject = aiResponse.subject_line || `Re: ${lead.email_subject_line}`;\nconst body = aiResponse.email_body || lead[`email_follow_up_day_${lead.follow_up_count === 1 ? '3' : '7'}`] || 'Following up on my previous email...';\n\n// Build complete email\nconst emailBody = `\n${body}\n\nBest regards,\nYour Name\nYour Company\n\n---\nUnsubscribe: {{unsubscribe_link}}\n`;\n\nreturn {\n  lead_id: lead.lead_id,\n  user_id: lead.user_id,\n  to_email: lead.email,\n  to_name: lead.company_name,\n  subject_line: subject,\n  email_body: emailBody,\n  from_email: 'hello@yourcompany.com',\n  from_name: 'Your Name',\n  \n  // AI insights\n  follow_up_type: aiResponse.follow_up_type,\n  follow_up_number: lead.follow_up_count + 1,\n  engagement_assessment: aiResponse.engagement_assessment,\n  ai_reasoning: aiResponse.reasoning,\n  \n  // For tracking\n  days_since_initial: lead.days_since_sent,\n  was_opened: lead.opened_at ? true : false,\n  was_clicked: lead.clicked_at ? true : false\n};"
      },
