    {
      "parameters": {
        "jsCode": "const aiResponse = $input.first().json.output || {};\nconst lead = $('Mock Follow-Up Ready').first().json;\n\nconst subject = aiResponse.subject_line || `Re: ${lead.email_subject_line || 'our previous conversation'}`;\nconst body = aiResponse.email_body || \n  (lead.follow_up_count === 1 ? lead.email_follow_up_day_3 : lead.email_follow_up_day_7) || \n  'Following up on my previous email...';\n\nconst emailBody = `${body}\n\nBest regards,\nMuhammad Fahad\nmohmmadfahad53408@gmail.com\n\n---\nTo unsubscribe, reply with UNSUBSCRIBE.`;\n\nreturn {\n  lead_id: lead.lead_id,\n  company_name: lead.company_name,\n  to_email: lead.email,\n  subject_line: subject,\n  email_body: emailBody,\n  follow_up_count: lead.follow_up_count,\n  priority: lead.priority\n};"
      },
