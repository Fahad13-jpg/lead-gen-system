    {
      "parameters": {
        "promptType": "define",
        "text": "=Analyze this lead and generate an intelligent follow-up email:\n\nLEAD PROFILE:\n- Company: {{ $json.company_name }}\n- Original Subject: {{ $json.email_subject_line }}\n- Days Since Last Email: {{ $json.days_since_sent }}\n- Follow-Up Number: {{ $json.follow_up_count }}\n- Priority: {{ $json.priority }}\n\nENGAGEMENT DATA:\n- Email Opened: {{ $json.opened_at ? 'Yes' : 'No' }}\n- Links Clicked: {{ $json.clicked_at ? 'Yes' : 'No' }}\n\nCONTEXT:\n- Pain Points: {{ $json.pain_points }}\n- Personalization: {{ $json.personalization_hook }}\n- Pre-written Day 3: {{ $json.email_follow_up_day_3 || 'N/A' }}\n- Pre-written Day 7: {{ $json.email_follow_up_day_7 || 'N/A' }}\n\n---\n\nSTRATEGY RULES:\n\nDay 3 + Email Opened:\n→ They saw it but didn't reply\n→ Provide value (resource, case study)\n→ Different angle\n\nDay 3 + NOT Opened:\n→ Try different subject line\n→ Shorter email\n→ Create curiosity\n\nDay 7:\n→ Acknowledge silence politely\n→ Ask simple yes/no question\n→ Easy to respond\n\nDay 14:\n→ Breakup email approach\n→ Give permission to say no\n→ Create FOMO\n\nReturn ONLY this JSON:\n\n{\n  \"follow_up_type\": \"value_add/different_angle/breakup\",\n  \"subject_line\": \"Re: ... (max 60 chars)\",\n  \"email_body\": \"Complete email body\",\n  \"reasoning\": \"Why this approach\",\n  \"engagement_assessment\": \"High/Medium/Low\",\n  \"recommended_next_step\": \"What if no response\",\n  \"tone\": \"helpful/urgent/casual\"\n}",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "You are an email follow-up expert. Analyze engagement data and create follow-up emails. Always respond with valid JSON containing the follow-up strategy and email content."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 2.2,
