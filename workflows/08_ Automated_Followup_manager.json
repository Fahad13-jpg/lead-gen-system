        "query": "UPDATE enriched_leads\nSET \n  follow_up_count = follow_up_count + 1,\n  last_contacted_at = NOW(),\n  last_follow_up_sent = NOW(),\n  next_follow_up_date = CASE\n    WHEN follow_up_count + 1 = 2 THEN NOW() + INTERVAL '4 days'\n    WHEN follow_up_count + 1 = 3 THEN NOW() + INTERVAL '7 days'\n    ELSE NULL\n  END\nWHERE lead_id = {{ $('Prepare Follow-Up Email').item.json.lead_id }}",
        "options": {}
