    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  el.lead_id,\n  cl.company_name,\n  cl.email,\n  cl.phone,\n  el.follow_up_count,\n  el.outreach_status,\n  el.sms_status,\n  el.whatsapp_status,\n  el.email_subject_line,\n  el.email_follow_up_day_3,\n  el.email_follow_up_day_7,\n  el.lead_score,\n  el.priority,\n  oa.opened_at,\n  oa.clicked_at,\n  EXTRACT(DAY FROM NOW() - oa.sent_at) as days_since_sent\nFROM enriched_leads el\nJOIN cleaned_leads cl ON el.lead_id = cl.id\nLEFT JOIN outreach_activities oa ON el.lead_id = oa.lead_id AND oa.channel = 'email'\nWHERE el.enrichment_stage = 3\nAND cl.email IS NOT NULL\nAND oa.replied_at IS NULL\nAND el.follow_up_count < 4\nAND el.outreach_status = 'email_sent'\nAND EXTRACT(DAY FROM NOW() - el.last_contacted_at) >= 3\nORDER BY el.lead_score DESC\nLIMIT 3",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        384,
        0
      ],
