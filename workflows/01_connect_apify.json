    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\n\n// Check if data exists\nif (!body) {\n  throw new Error('No data received');\n}\n\n// Check user_id\nif (!body.user_id) {\n  throw new Error('user_id is required');\n}\n\n// Check API key\nif (!body.apify_api_key) {\n  throw new Error('apify_api_key is required');\n}\n\n// Validate key format\nif (!body.apify_api_key.startsWith('apify_api_')) {\n  throw new Error('Invalid Apify key format');\n}\n\n// Return cleaned data\nreturn {\n  user_id: parseInt(body.user_id),\n  apify_api_key: body.apify_api_key.trim()\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        32,
        -32
      ],
      "id": "f6f2a701-b1ac-414e-9995-a50743ed45a9",
      "name": "Validate Input"
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst validateNode = $('Validate Input').first().json;\n\n// Check if error\nif (response.error) {\n  return {\n    valid: false,\n    user_id: validateNode.user_id,\n    error_message: 'Invalid API key'\n  };\n}\n\n// Success\nreturn {\n  valid: true,\n  user_id: validateNode.user_id,\n  apify_api_key: validateNode.apify_api_key,\n  apify_username: response.data.username || 'Unknown'\n};"
      },
