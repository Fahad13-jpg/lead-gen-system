      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  el.lead_id,\n  cl.company_name,\n  cl.email,\n  el.email_should_use,\n  el.email_subject_line,\n  el.email_opening,\n  el.email_body_template,\n  el.primary_channel,\n  el.lead_score,\n  el.priority\nFROM enriched_leads el\nJOIN cleaned_leads cl ON el.lead_id = cl.id\nWHERE el.enrichment_stage = 3\nAND el.email_should_use = TRUE\nAND cl.email IS NOT NULL\nAND el.outreach_status IS NULL\nORDER BY el.lead_score DESC\nLIMIT 10",
        "options": {}
