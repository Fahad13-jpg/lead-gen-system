    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const leadData = $input.item.json;\n\nconst subject = leadData.email_subject_line || `Following up: ${leadData.company_name}`;\nconst opening = leadData.email_opening || '';\nconst bodyTemplate = leadData.email_body_template || '';\n\nconst emailBody = `${opening}\n\n${bodyTemplate}\n\nBest regards,\nMuhammad Fahad\nLead Generation System\nmohmmadfahad53408@gmail.com\n\n---\nYou're receiving this because we thought it might be valuable for ${leadData.company_name}.\nTo unsubscribe, reply with UNSUBSCRIBE.`;\n\nreturn {\n  lead_id: leadData.lead_id,\n  to_email: leadData.email,\n  to_name: leadData.company_name,\n  subject_line: subject,\n  email_body: emailBody,\n  priority: leadData.priority,\n  lead_score: leadData.lead_score\n};"
      },
