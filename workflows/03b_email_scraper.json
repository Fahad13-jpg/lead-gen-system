    {
      "parameters": {
        "jsCode": "const lead     = $('Get Tier 2 Leads').item.json;\nconst userInfo = $input.item.json;\n\nif (!userInfo.apify_api_key) {\n  throw new Error('No Apify key for user ' + lead.user_id);\n}\n\nlet url = lead.website.trim();\nif (!url.startsWith('http')) url = 'https://' + url;\n\nreturn {\n  staging_id:    lead.id,\n  job_id:        lead.job_id,\n  user_id:       lead.user_id,\n  company_name:  lead.company_name,\n  website:       url,\n  apify_api_key: userInfo.apify_api_key,\n  apify_input: {\n    startUrls: [{ url: url }],\n    maxDepth: 2,\n    maxPages: 5,\n    contactInfoFrom: \"all\"\n  }\n};"
      },
