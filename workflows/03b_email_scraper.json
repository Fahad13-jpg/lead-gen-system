    },
    {
      "parameters": {
        "jsCode": "const results  = $input.all();\nconst prepData = $('Get Apify Data').first().json;\n\nlet email = null;\n\nfor (const item of results) {\n  const r = item.json;\n  if (r.emails?.length > 0)                { email = r.emails[0]; break; }\n  if (r.email)                              { email = r.email;     break; }\n  if (r.contactInfo?.emails?.length > 0)   { email = r.contactInfo.emails[0]; break; }\n}\n\nif (email) email = email.toLowerCase().trim();\n\nreturn {\n  staging_id:   prepData.staging_id,\n  user_id:      prepData.user_id,\n  company_name: prepData.company_name,\n  email_found:  email || ''\n};"
      },
