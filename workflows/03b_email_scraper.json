        "jsCode": "const lead = $input.item.json;\n\nlet url = lead.website.trim();\nif (!url.startsWith('http://') && !url.startsWith('https://')) {\n  url = 'https://' + url;\n}\nurl = url.replace(/\\/+$/, '');\n\nreturn {\n  staging_id:   lead.id,\n  job_id:       lead.job_id,\n  user_id:      lead.user_id,\n  company_name: lead.company_name,\n  website:      url\n};"
