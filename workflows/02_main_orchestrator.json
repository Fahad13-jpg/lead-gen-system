    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\n\n// Validate all required fields\nif (!body.user_id) throw new Error('user_id required');\nif (!body.job_name) throw new Error('job_name required');\nif (!body.source) throw new Error('source required');\nif (!body.search_query) throw new Error('search_query required');\nif (!body.location) throw new Error('location required');\nif (!body.max_results) throw new Error('max_results required');\n\n// Validate source\nif (!['google_maps'].includes(body.source)) {\n  throw new Error('Invalid source');\n}\n\n// Validate max_results\nconst maxResults = parseInt(body.max_results);\nif (maxResults < 1 || maxResults > 500) {\n  throw new Error('max_results must be 1-500');\n}\n\nreturn {\n  user_id: parseInt(body.user_id),\n  job_name: body.job_name,\n  source: body.source,\n  search_query: body.search_query,\n  location: body.location,\n  max_results: maxResults\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        208,
        0
      ],
      "id": "3ac8ac47-a481-453e-ad96-ea2752bfe056",
