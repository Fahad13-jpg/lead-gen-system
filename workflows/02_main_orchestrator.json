    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  id, \n  email, \n  apify_api_key,\n  apify_status,\n  apify_credit\nFROM users \nWHERE id = {{ $json.user_id }}\nLIMIT 1",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
