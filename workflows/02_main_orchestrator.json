          "id": "Scc3yxojKZkvXpOL",
          "name": "Lead Database"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const user = $input.first().json;\nconst request = $('Validate Request').first().json;\n\n// Check if user exists\nif (!user || !user.id) {\n  return {\n    error: true,\n    code: 'USER_NOT_FOUND',\n    message: 'User not found'\n  };\n}\n\n// Check Apify key\nif (!user.apify_api_key) {\n  return {\n    error: true,\n    code: 'APIFY_NOT_CONNECTED',\n    message: 'Please connect Apify account first'\n  };\n}\n\n// Check status\nif (user.apify_status !== 'active') {\n  return {\n    error: true,\n    code: 'APIFY_INVALID',\n    message: 'Apify key is invalid or inactive'\n  };\n}\n\n// Calculate cost\nconst estimatedCost = (request.max_results / 100) * 0.01;\n\n// Check credit\nif (user.apify_credit < estimatedCost) {\n  return {\n    error: true,\n    code: 'INSUFFICIENT_CREDIT',\n    message: `Need $${estimatedCost.toFixed(4)}, have $${user.apify_credit.toFixed(2)}`\n  };\n}\n\n// All good\nreturn {\n  error: false,\n  user_id: user.id,\n  apify_api_key: user.apify_api_key,\n  estimated_cost: estimatedCost,\n  job_name: request.job_name,\n  source: request.source,\n  search_query: request.search_query,\n  location: request.location,\n  max_results: request.max_results\n};"
      },
