    {
      "parameters": {
        "jsCode": "const leads = $input.all();\nconst enrichedLeads = [];\n\n// Helper: Extract domain from email\nfunction extractDomain(email) {\n  if (!email) return null;\n  const match = email.match(/@([a-zA-Z0-9.-]+\\.[a-zA-Z]{2,})$/);\n  return match ? match[1].toLowerCase() : null;\n}\n\n// Helper: Extract domain from website\nfunction extractDomainFromWebsite(website) {\n  if (!website) return null;\n  try {\n    const url = new URL(website.startsWith('http') ? website : 'https://' + website);\n    return url.hostname.replace(/^www\\./, '').toLowerCase();\n  } catch {\n    return null;\n  }\n}\n\n// Helper: Detect country from phone\nfunction detectGeoFromPhone(phone) {\n  if (!phone) return { country: 'Unknown', timezone: 'UTC', code: 'XX' };\n  \n  const geoMap = {\n    '+1': { country: 'United States', timezone: 'America/New_York', code: 'US' },\n    '+44': { country: 'United Kingdom', timezone: 'Europe/London', code: 'GB' },\n    '+92': { country: 'Pakistan', timezone: 'Asia/Karachi', code: 'PK' },\n    '+91': { country: 'India', timezone: 'Asia/Kolkata', code: 'IN' }\n  };\n  \n  for (const [prefix, data] of Object.entries(geoMap)) {\n    if (phone.startsWith(prefix)) return data;\n  }\n  \n  return { country: 'Unknown', timezone: 'UTC', code: 'XX' };\n}\n\n// Process each lead\nfor (const item of leads) {\n  const lead = item.json;\n  \n  const emailDomain = extractDomain(lead.email);\n  const websiteDomain = extractDomainFromWebsite(lead.website);\n  const primaryDomain = websiteDomain || emailDomain;\n  const phoneGeo = detectGeoFromPhone(lead.phone);\n  \n  enrichedLeads.push({\n    lead_id: lead.id,\n    user_id: lead.user_id,\n    company_name: lead.company_name,\n    domain: primaryDomain,\n    detected_country: phoneGeo.country,\n    detected_timezone: phoneGeo.timezone,\n    phone_country_code: phoneGeo.code,\n    website: lead.website,\n    has_website: lead.website ? true : false,\n    enrichment_stage: 1\n  });\n}\n\nreturn enrichedLeads;"
      },
