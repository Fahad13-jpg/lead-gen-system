    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  cl.id,\n  cl.user_id,\n  cl.company_name,\n  cl.email,\n  cl.phone,\n  cl.website,\n  cl.city,\n  cl.state,\n  cl.country,\n  cl.email_valid,\n  cl.category,\n  cl.rating,\n  cl.review_count\nFROM cleaned_leads cl\nLEFT JOIN enriched_leads el ON cl.id = el.lead_id\nWHERE el.id IS NULL\nAND (cl.email_valid = TRUE OR cl.phone IS NOT NULL)\nORDER BY \n  CASE \n    WHEN cl.email_valid = TRUE THEN 1\n    WHEN cl.rating >= 4.5 THEN 2\n    ELSE 3\n  END\nLIMIT 10",
        "options": {}
      },
