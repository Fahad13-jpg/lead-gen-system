      "parameters": {
        "jsCode": "const items = $input.all();\nconst leadCount = items.length;\nconst checkNode = $('Check If Succeeded').first().json;\n\n// Cost: $0.01 per 100 leads\nconst actualCost = (leadCount / 100) * 0.01;\n\nreturn {\n  job_id: checkNode.job_id,\n  user_id: checkNode.user_id,\n  runId: checkNode.runId,\n  leads_scraped: leadCount,\n  cost_usd: actualCost\n};"
