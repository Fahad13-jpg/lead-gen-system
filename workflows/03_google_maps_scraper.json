    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\n\n// Validate required fields\nif (!body.job_id) throw new Error('job_id required');\nif (!body.user_id) throw new Error('user_id required');\nif (!body.apify_api_key) throw new Error('apify_api_key required');\nif (!body.search_query) throw new Error('search_query required');\nif (!body.location) throw new Error('location required');\nif (!body.max_results) throw new Error('max_results required');\n\n// Prepare Apify actor input\nconst apifyInput = {\n  searchStringsArray: [body.search_query],\n  locationQuery: body.location,\n  maxCrawledPlacesPerSearch: parseInt(body.max_results),\n  language: \"en\",\n  includeWebsites: true,\n  includeEmails: true,\n  includePhoneNumbers: true\n};\n\nreturn {\n  job_id: parseInt(body.job_id),\n  user_id: parseInt(body.user_id),\n  apify_api_key: body.apify_api_key,\n  apifyInput: apifyInput,\n  max_results: parseInt(body.max_results)\n};"
      },
