        "query": "UPDATE users\nSET \n  apify_credit = GREATEST(0, apify_credit - {{ $json.cost_usd }}),\n  apify_status = CASE \n    WHEN (apify_credit - {{ $json.cost_usd }}) < 0.10 THEN 'depleted'\n    ELSE apify_status\n  END\nWHERE id = {{ $json.user_id }}",
